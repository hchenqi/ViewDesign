{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20"
      }
    },
    {
      "name": "host-windows",
      "inherits": "base",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "host-linux",
      "inherits": "base",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "host-macos",
      "inherits": "base",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "macOS"
      }
    },
    {
      "name": "ninja",
      "hidden": true,
      "generator": "Ninja"
    },
    {
      "name": "vs2026",
      "hidden": true,
      "generator": "Visual Studio 18 2026"
    },
    {
      "name": "msvc",
      "hidden": true,
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl",
        "CMAKE_CXX_FLAGS": "/EHsc /DUNICODE /D_UNICODE /utf-8"
      }
    },
    {
      "name": "msvc-x64",
      "inherits": "msvc",
      "hidden": true,
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "msvc-x86",
      "inherits": "msvc",
      "hidden": true,
      "architecture": {
        "value": "x86",
        "strategy": "external"
      }
    },
    {
      "name": "mingw-gcc-x64",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "x86_64-w64-mingw32-g++"
      }
    },
    {
      "name": "mingw-gcc-x86",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "i686-w64-mingw32-g++"
      }
    },
    {
      "name": "mingw-clang-x64",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS": "-Wno-switch"
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "win32",
      "hidden": true,
      "cacheVariables": {
        "BACKEND": "win32"
      }
    }
  ]
}